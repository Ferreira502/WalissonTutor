{
  "name": "walisson-tutor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --config frontend/vite.config.ts\" \"node --watch backend/index.js\"",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "node --watch backend/index.js",
    "build": "tsc --noEmit -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:frontend": "tsc --noEmit -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "start": "node backend/index.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-spring/web": "^10.1.2",
    "@xyflow/react": "^12.11.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
